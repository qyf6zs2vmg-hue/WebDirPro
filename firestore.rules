rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Simplified rules for easy setup (Public Access)
    // NOTE: In a production app, you should use real authentication.
    
    match /categories/{categoryId} {
      allow read, write: if true;
    }

    match /items/{itemId} {
      allow read, write: if true;
    }

    match /reviews/{reviewId} {
      allow read, write: if true;
    }

    match /submissions/{subId} {
      allow read, write: if true;
    }

    match /users/{userId} {
      allow read, write: if true;
    }
  }
}
